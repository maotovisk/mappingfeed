# Required secrets
DISCORD_TOKEN=
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=

# Optional overrides
API_PORT=5000
OSU_BASE_URL=https://osu.ppy.sh
FEED_POLL_INTERVAL_SECONDS=30
FEED_DISPATCH_INTERVAL_SECONDS=120
FEED_EVENTS_BATCH_SIZE=25
FEED_DISPATCH_BATCH_SIZE=10
FEED_API_CACHE_MINUTES=10
FEED_ENABLE_API_BACKFILL_WORKER=true
FEED_API_BACKFILL_STARTUP_DELAY_SECONDS=20
FEED_API_BACKFILL_REPEAT_INTERVAL_MINUTES=0
FEED_API_BACKFILL_THROTTLE_MILLISECONDS=1000
FEED_API_BACKFILL_BATCH_SIZE=128
LOG_LEVEL_DEFAULT=Information
LOG_LEVEL_MICROSOFT=Warning
LOG_LEVEL_HOSTING_LIFETIME=Information
LOG_LEVEL_SYSTEM_NET_HTTP=Warning
